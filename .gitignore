# Careercraft AI Root .gitignore

# Dependency directories
**/node_modules/
node_modules/

# Local Environment Variables (CRITICAL - DO NOT REMOVE)
**/.env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Production/Distribution builds
**/dist/
**/dist-ssr/
**/out/
dist/

# Log files
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editor & System directories
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local Uploads / Temporary Resumes
**/uploads/*
!**/uploads/.gitkeep
backend/uploads/*
!backend/uploads/.gitkeep
